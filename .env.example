# CortexMark runtime path overrides
# Precedence: CLI args > environment variables > .env > config file > repo-relative defaults

# Root discovery
# PROJECT_ROOT=/absolute/path/to/pdf-to-markdown-pipeline

# Config / source selection
# CORTEXMARK_CONFIG=configs/pipeline.yaml
# CORTEXMARK_SOURCE_ID=default
# PIPELINE_ENGINE=dual

# Shared roots
# DATA_DIR=data
# OUTPUT_DIR=outputs
# REPORT_DIR=outputs/quality
# LOG_DIR=outputs/logs
# CHECKPOINT_DIR=checkpoints
# CACHE_DIR=.cache/cortexmark
# MODEL_DIR=models
# EXTERNAL_BIN_DIR=/opt/tools/bin

# Optional direct overrides (win over DATA_DIR / OUTPUT_DIR)
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
# OUTPUT_RAW_MD=outputs/raw_md
# OUTPUT_CLEANED_MD=outputs/cleaned_md
# OUTPUT_CHUNKS=outputs/chunks
# OUTPUT_SEMANTIC_CHUNKS=outputs/semantic_chunks
# MANIFEST_FILE=outputs/.manifest.json
# PLUGIN_DIR=plugins
# TEST_RESOURCES_DIR=tests/resources
